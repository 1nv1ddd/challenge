# Получить ключ: https://routerai.ru/
ROUTERAI_API_KEY=

# Опционально: true — потоковый ответ по SSE (если у провайдера стрим стабилен). По умолчанию выкл.
# ROUTERAI_USE_STREAM=1

# Опционально: POST JSON при каждом тике планировщика (Slack/Discord/n8n и т.д.)
# SCHEDULER_WEBHOOK_URL=

# RAG День 23–24 (опционально): порог отсечения чанков при filtered/rewrite; порог «не знаю» без keyword-хитов
# RAG_MIN_SIMILARITY=0
# RAG_ANSWER_MIN_SCORE=0.25

# День 28 (опционально): локальные эмбеддинги через Ollama вместо RouterAI.
# Для этого — `ollama pull bge-m3` и пересобрать индекс (scripts/build_rag_index.py).
# RAG_EMBEDDINGS_URL=http://localhost:11434/v1/embeddings
# RAG_EMBEDDING_MODEL=bge-m3

# Локальные LLM-провайдеры (Ollama). На VPS через SSH reverse-tunnel:
#   OLLAMA_BASE_URL=http://172.28.0.1:11434
# OLLAMA_BASE_URL=http://localhost:11434
